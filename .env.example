GEMINI_API_KEY=your_gemini_api_key_here
# some original modules read GOOGLE_API_KEY instead — set both to be safe
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_ROUTER_MODEL=gemini-flash-latest

# finance/database (only needed if you use the finance agent)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cofoundai_finance
